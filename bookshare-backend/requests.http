### ==========================================
### BOOKSHARE API - TESTES CONSOLIDADOS
### Arquivo Master com todos os testes
### ==========================================

### **01-SETUP** =========================================
### Criar usuário DONO
# @name dono
POST http://localhost:3002/users
Content-Type: application/json

{
  "nome": "Dono",
  "email": "dono@teste.com",
  "senha": "senhaSegura123"
}

###
# Criar usuário LEITOR 1
# @name leitor1
POST http://localhost:3002/users
Content-Type: application/json

{
  "nome": "Leitor 1",
  "email": "leitor1@teste.com",
  "senha": "senhaSegura123"
}

###
# Criar usuário LEITOR 2
# @name leitor2
POST http://localhost:3002/users
Content-Type: application/json

{
  "nome": "Leitor 2",
  "email": "leitor2@teste.com",
  "senha": "senhaSegura123"
}

###
# Criar livro base (para testes de empréstimo)
# @name livro
POST http://localhost:3002/books
Content-Type: application/json

{
  "titulo": "Clean Code",
  "autor": "Uncle Bob",
  "isbn": "111",
  "donoId": "{{dono.response.body.id}}"
}

###
# Criar livro do dono (para teste de auto-empréstimo)
# @name livro_do_dono
POST http://localhost:3002/books
Content-Type: application/json

{
  "titulo": "Meu Livro",
  "autor": "Eu",
  "isbn": "222",
  "donoId": "{{dono.response.body.id}}"
}

